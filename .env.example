# Base RPC URL (should support event log queries for optimal V4 pool discovery)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Cache refresh interval (number of quotes before refreshing cached routes)
BASALT_CACHE_REFRESH_INTERVAL=10

# Cache directory (defaults to ~/.basalt if not set)
# BASALT_CACHE_DIR=/path/to/cache
